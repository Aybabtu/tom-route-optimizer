{
  "name": "tom-route-optimizer",
  "version": "0.1.0",
  "description": "Truck routing optimizer for Oakland County TOM",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:server": "cd server && npm run dev",
    "dev:all": "concurrently \"npm run dev\" \"npm run dev:server\"",
