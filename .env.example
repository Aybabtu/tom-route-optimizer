# API Configuration
#
# Local development — point directly at the live PHP API (CORS is enabled):
VITE_API_URL=https://bidmyroute.com/road_data/tom-route-optimizer/server/api.php
#
# Or run PHP locally:
#   php -S localhost:3001 server/api.php
# Then use:
# VITE_API_URL=http://localhost:3001
#
# Production builds pick up .env.production automatically — no action needed.
